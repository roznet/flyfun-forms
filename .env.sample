# Required in production
ENVIRONMENT=production
DATABASE_URL=mysql+pymysql://user:pass@shared-mysql:3306/flyfun
JWT_SECRET=change-me-in-production

# OAuth (shared with flyfun-weather — same credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In – native iOS token validation
APPLE_APP_IDS=net.ro-z.flyfun-forms

# Optional: Apple web OAuth (only if using browser-based flow)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# Optional: airports.db for name resolution
# AIRPORTS_DB=/app/data/airports.db
