# Required in production
ENVIRONMENT=production
DATABASE_URL=mysql+pymysql://user:pass@shared-mysql:3306/flyfun
JWT_SECRET=change-me-in-production

# OAuth (shared with flyfun-weather — same credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Apple Sign In (required for App Store)
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# Optional: airports.db for name resolution
# AIRPORTS_DB=/app/data/airports.db
