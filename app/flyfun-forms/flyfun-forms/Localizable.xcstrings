    "%@  %@  %@" : {
      "comment" : "A row of text displaying the origin and destination ICAO codes of a flight, with an editable pencil icon in the trailing end. The first argument is the origin ICAO code, formatted to be three characters wide. The second argument is the “arrow.right” symbol. The third argument is the destination ICAO code, formatted to be three characters wide.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@  %2$@  %3$@"
