{
  "icao_list": ["LFQA", "LFQB", "LFGJ"],
  "label": "Préavis Douane (CODT Metz)",
  "template": "lfqa_customs_form.pdf",
  "type": "pdf_acroform",
  "version": "2.0",
  "time_reference": "utc",
  "max_crew": 3,
  "max_passengers": 3,
  "send_to": "codt-metz@douane.finances.gouv.fr",
  "default_observations": "Rien à déclarer",
  "date_format": "%d/%m/%Y",
  "has_connecting_flight": false,
  "extra_fields": [],
  "required_fields": {
    "flight": ["origin", "destination", "departure_date", "departure_time_utc", "arrival_date", "arrival_time_utc"],
    "aircraft": ["registration", "type"],
    "crew": ["first_name", "last_name", "dob", "nationality", "id_number"],
    "passengers": ["first_name", "last_name", "dob", "nationality", "id_number"]
  },
  "field_map": {
    "airport.icao": "AIRPORTICAO",
    "direction.arrival_mark": "DEMANDE DARRIVEE",
    "direction.departure_mark": "DEMANDE DE DEPART",
    "flight.nature.private": "PASSENGERFLIGHT",
    "flight.nature.fret": "CARGOFLIGHT",
    "flight.observations": "OBSERVATIONS",
    "flight.origin": "ORIGINICAO",
    "routing.departure_place": "ORIGINCITY",
    "origin.country": "ORIGINCOUNTRY",
    "flight.destination": "DESTINATIONICAO",
    "routing.arrival_place": "DESTINATIONCITY",
    "destination.country": "DESTINATIONCOUNTRY",
    "arrival.date": "ARRIVALFLIGHTDATE",
    "arrival.time": "ARRIVALFLIGHTTIME",
    "arrival.registration": "ARRIVALAIRCRAFTREG",
    "arrival.type": "ARRIVALAIRCRAFTTYPE",
    "arrival.owner": "ARRIVALOWNER",
    "arrival.nature": "ARRIVALFLIGHTTYPE",
    "departure.date": "DEPARTUREFLIGHTDATE",
    "departure.time": "DEPARTUREFLIGHTTIME",
    "departure.registration": "DEPARTUREAIRCRAFTREG",
    "departure.type": "DEPARTUREAIRCRAFTTYPE",
    "departure.owner": "DEPARTUREOWNER",
    "departure.nature": "DESTINATIONFLIGHTTYPE",
    "crew[{i}].last_name": "NOM NAMERow{n}",
    "crew[{i}].first_name": "PRENOMRow{n}",
    "crew[{i}].dob": "DATE DE NAISSANCERow{n}",
    "crew[{i}].nationality": "NATIONALITE NATIONALITYRow{n}",
    "crew[{i}].id_number": "NPASSEPORTCI PASSPORT NCIRow{n}",
    "passengers[{i}].last_name": "NOM NAMERow{n}_2",
    "passengers[{i}].first_name": "PRENOMRow{n}_2",
    "passengers[{i}].dob": "DATE DE NAISSANCERow{n}_2",
    "passengers[{i}].nationality": "NATIONALITE NATIONALITYRow{n}_2",
    "passengers[{i}].id_number": "NPASSEPORTCI PASSPORT NCIRow{n}_2"
  }
}
