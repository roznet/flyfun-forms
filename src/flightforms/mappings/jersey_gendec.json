{
  "icao": "EGJJ",
  "label": "Customs General Declaration",
  "template": "jersey_gendec.pdf",
  "type": "pdf_acroform",
  "version": "1.0",
  "time_reference": "utc",
  "max_crew": 4,
  "max_passengers": 9,
  "date_format": "%d/%m/%Y",
  "has_connecting_flight": true,
  "send_to": "gendec@gov.je",
  "email": {
    "to": ["gendec@gov.je", "sbgendecs@jersey.pnn.police.uk"],
    "subject": "General Declaration - {registration} - {date}"
  },
  "extra_fields": [
    {"key": "phone", "label": "Crew phone", "type": "text", "required": false},
    {"key": "email", "label": "Crew email", "type": "text", "required": false},
    {"key": "owner_email", "label": "Owner email", "type": "text", "required": false}
  ],
  "required_fields": {
    "flight": ["origin", "destination", "departure_date", "arrival_date", "arrival_time_utc"],
    "aircraft": ["registration", "type"],
    "crew": ["first_name", "last_name", "nationality", "id_number"],
    "passengers": ["first_name", "last_name", "nationality", "id_number"]
  },
  "field_map": {
    "aircraft.registration": "Registration",
    "aircraft.type": "RegistrationType",
    "aircraft.usual_base": "BasedAt",
    "aircraft.owner": "OwnerName",
    "aircraft.owner_address": "OwnerAddress",
    "extra.owner_email": "OwnerEmail",
    "extra.phone": "CrewPhoneContact",
    "extra.email": "CrewPhoneEmail",

    "airport.arrival.from": "ArrivalInToJerseyAirportCode",
    "airport.arrival.from_name": "ArrivalInToJerseyText",
    "airport.arrival.date": "ArrivalOnDate",
    "airport.arrival.time": "ArrivalOnTime",

    "airport.departure.to": "DepartureFromJerseyAirportCode",
    "airport.departure.to_name": "DepartureFromJerseyText",
    "airport.departure.date": "DepartureOnDate",
    "airport.departure.time": "DepartureOnTime",

    "flight.nature.private=Pleasure": "PurposeOfJourney",
    "flight.nature.business=Business": "PurposeOfJourney",
    "static./No": "GoodsToDeclare",

    "crew[{i}].type": "TypeRow{n}",
    "crew[{i}].last_name": "SurnamesRow{n}",
    "crew[{i}].first_name": "ForenamesRow{n}",
    "crew[{i}].dob": "DateOfBirthRow{n}",
    "crew[{i}].place_of_birth": "TownOfBirthRow{n}",
    "crew[{i}].nationality": "NationalityRow{n}",
